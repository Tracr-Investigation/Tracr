{
  "manifest_version": 3,
  "name": "Tracr - Archivage de sources",
  "version": "0.1.0",
  "description": "Capture et archive des sources (pages, screenshots, médias) horodatées dans une enquête Tracr.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "pageCapture",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tracr - Archiver une source",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
