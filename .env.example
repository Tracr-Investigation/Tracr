# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Database URL
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@localhost:5432/POSTGRES_DB
REDIS_URL=redis://localhost:6379

# FastAPI
SECRET_KEY=
DEBUG=True

COMPOSE_PROJECT_NAME=tracr

# MinIO (stockage objet des captures de sources)
# MINIO_ENDPOINT : laisser "minio:9000" en Docker, "localhost:9000" hors Docker
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=tracr-sources
MINIO_SECURE=False
MINIO_KMS_SECRET_KEY=tracr-key:CHANGE_ME_BASE64_32_BYTES
